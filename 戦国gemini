      addLog(`${wp.name} を装備した！`, 'system');
    } else {
      const currentEquip = equippedWeapons[generalId];
      if (currentEquip) {
        setInventoryWeapons(prev => ({ ...prev, [currentEquip]: (prev[currentEquip] || 0) + 1 }));
        setEquippedWeapons(prev => {
          const next = { ...prev };
          delete next[generalId];
          return next;
        });
        addLog(`装備を外した。`, 'system');
      }
    }
    setShowWeaponModalFor(null);
  };

  const useItem = (itemId) => {
    if (inventory[itemId] <= 0) return;
    if (itemId === 'drum') {
      setInventory(prev => ({ ...prev, drum: prev.drum - 1 }));
      setActiveBuff('drum');
      addLog('【陣太鼓】を使用した！次の出陣で部隊の戦力が1.5倍になる。', 'rare');
    } else if (itemId === 'hora') {
      setInventory(prev => ({ ...prev, hora: prev.hora - 1 }));
      setActiveBuff('hora');
      addLog('【法螺貝】を使用した！次の出陣で部隊の戦力が1.2倍になる。', 'rare');
    } else if (itemId === 'tactics') {
      setShowItemModal('tactics');
    }
  };

  const applyTactics = (generalId, count = 1) => {
    if (inventory.tactics < count) return;
    setInventory(prev => ({ ...prev, tactics: prev.tactics - count }));
    
    let leveledUpCount = 0;
    let finalLevel = 0;
    const target = ownedGenerals.find(g => g.uniqueId === generalId);

    setOwnedGenerals(prevGenerals => prevGenerals.map(g => {
      if (g.uniqueId !== generalId) return g;
      let newExp = g.currentExp + 500 * count;
      let newLevel = g.level;
      while (newExp >= newLevel * 100) {
        newExp -= newLevel * 100;
        newLevel++;
        leveledUpCount++;
      }
      finalLevel = newLevel;
      return { ...g, level: newLevel, currentExp: newExp };
    }));
    
    if (leveledUpCount > 0) {
      addLog(`【昇級】${target.name}に兵法書を${count}冊使い、レベル${finalLevel}に昇級した！`, 'rare');
    } else {
      addLog(`【兵法書】${target.name}に${count}冊使い、経験値${500 * count}を与えた。`, 'success');
    }
    
    if (inventory.tactics - count <= 0) {
      setShowItemModal(null);
    }
  };

  const drawGacha = (times) => {
    const cost = times === 1 ? 200 : 1900;
    if (gold < cost) {
      addLog(`小判が不足しておる。(${cost}小判必要)`, 'error');
      return;
    }
    setGold(prev => prev - cost);
    const newGenerals = [];
    const drawLogs = [];

    const drawSe = new Audio('https://cdn.pixabay.com/download/audio/2021/08/04/audio_341edde289.mp3');
    drawSe.volume = bgmVolume;
    drawSe.play().catch(() => { console.log("SEの自動再生がブロックされました"); });

    for (let i = 0; i < times; i++) {
      const rand = Math.random() * 100;
      let rarity = 3;
      if (rand < 5) rarity = 5;
      else if (rand < 20) rarity = 4;
      else if (rand < 50) rarity = 3;
      else if (rand < 80) rarity = 2; 
      else rarity = 1; 
      
      const candidates = MASTER_GENERALS.filter(g => g.rarity === rarity);
      const selected = candidates[Math.floor(Math.random() * candidates.length)];
      
      const newGeneral = { ...selected, uniqueId: generateId(), level: 1, currentExp: 0, breakthrough: 0 };
      newGenerals.push(newGeneral);
      
      let logStr = `登用: [星${rarity}] ${selected.name} が配下に加わった！`;
      if (rarity === 5) logStr = `【大吉報】` + logStr;
      drawLogs.push({ id: generateId(), text: logStr, type: rarity === 5 ? 'rare' : 'normal' });
    }

    setOwnedGenerals(prev => [...prev, ...newGenerals]);
    setLogs(prev => [...prev, ...drawLogs]);
    setGachaResult(newGenerals);
  };

  const addToDeck = (general) => {
    const newDecks = [...decks];
    let alreadyEquipped = false;
    
    for (let d = 0; d < newDecks.length; d++) {
      const idx = newDecks[d].indexOf(general.uniqueId);
      if (idx !== -1) {
        newDecks[d][idx] = null;
        alreadyEquipped = true;
      }
    }

    const currentDeck = [...newDecks[activeDeckIndex]];
    const emptyIndex = currentDeck.indexOf(null);
    
    if (emptyIndex !== -1) {
      currentDeck[emptyIndex] = general.uniqueId;
      newDecks[activeDeckIndex] = currentDeck;
      setDecks(newDecks);
      if (alreadyEquipped) addLog(`${general.name}の配置を変更した。`);
      else addLog(`${general.name}を第${activeDeckIndex + 1}部隊に配属した。`);
    } else {
      addLog(`第${activeDeckIndex + 1}部隊は満員じゃ！誰かを外すのじゃ。`, 'error');
    }
  };

  const removeFromDeck = (deckIdx, slotIdx) => {
    const newDecks = [...decks];
    const uniqueId = newDecks[deckIdx][slotIdx];
    if (uniqueId) {
      const removedGeneral = ownedGenerals.find(g => g.uniqueId === uniqueId);
      if (removedGeneral) addLog(`${removedGeneral.name}を編制から外した。`);
      newDecks[deckIdx][slotIdx] = null;
      setDecks(newDecks);
    }
  };

  const calculateDeckPower = (deckIdx) => {
    const targetDeck = decks[deckIdx].map(id => id ? ownedGenerals.find(g => g.uniqueId === id) || null : null);
    return targetDeck.reduce((sum, g) => {
      if (!g) return sum;
      const levelMultiplier = 1 + ((g.level - 1) * 0.1);
      const breakthroughMultiplier = 1 + ((g.breakthrough || 0) * 0.1);
      const allianceBuffMultiplier = 1 + ((allianceInfo.level - 1) * 0.05);
      let baseStat = (g.atk + g.int + g.def) * breakthroughMultiplier;
      const weaponId = equippedWeapons[g.uniqueId];
      if (weaponId) {
        const wp = MASTER_WEAPONS.find(w => w.id === weaponId);
        if (wp) baseStat += (wp.atk + wp.int + wp.def);
      }
      return sum + Math.floor(baseStat * levelMultiplier * allianceBuffMultiplier * 10);
    }, 0);
  };

  const startBattle = (land, deckIdx, isDefense = false, customEnemyPower = null, customEnemyName = null) => {
    if (battlingLandId) return;

    if (diplomacyRelations[land.owner] === 'alliance') {
       addLog(`【同盟】${land.owner}とは同盟を結んでおる。攻め込むなら先に同盟を破棄せよ！`, "error");
       return;
    }

    const activeDeckGenerals = decks[deckIdx]
      .map(id => id ? ownedGenerals.find(g => g.uniqueId === id) || null : null)
      .filter(g => g !== null);

    if (activeDeckGenerals.length === 0) {
      addLog(`第${deckIdx + 1}部隊には誰も出陣しておらんぞ！編制せよ。`, 'error');
      if (!isDefense) {
        setActiveTab('deck');
        setActiveDeckIndex(deckIdx);
      }
      return;
    }

    setBattlingLandId(land.id);
    if(isDefense) setInvasionEvent(null); 

    const deckPower = calculateDeckPower(deckIdx);
    const targetEnemyPower = customEnemyPower || land.power;
    const targetEnemyName = customEnemyName || (occupiedLands.includes(land.id) ? '賊軍' : `${land.owner}軍`);
    
    const wasBgmPlaying = isBgmPlaying;
    if (wasBgmPlaying && audioRef.current) {
      audioRef.current.pause();
    }

    setBattleScene({ 
      phase: 'intro', 
      land, 
      activeDeck: activeDeckGenerals, 
      deckPower, 
      enemyPower: targetEnemyPower, 
      enemyName: targetEnemyName,
      resultText: '', 
      isVictory: false, 
      isDraw: false, 
      wasBgmPlaying,
      isDefense 
    });

    setTimeout(() => {
      setBattleScene(prev => ({ ...prev, phase: 'clash' }));
      
      const clashSe = new Audio('https://cdn.pixabay.com/download/audio/2022/03/15/audio_24e00db620.mp3');
      clashSe.volume = bgmVolume;
      clashSe.loop = true; 
      clashSe.play().catch(() => { console.log("SEの自動再生がブロックされました"); });
      
      const factions = new Set(activeDeckGenerals.map(g => g.faction));
      if (factions.size === 1 && activeDeckGenerals.length === 5) {
         addLog(`【陣営効果極大】5人全員が「${activeDeckGenerals[0].faction}」のため、ステータスが大幅上昇！`, 'rare');
      }

      setTimeout(() => {
        clashSe.pause();
        let finalPower = deckPower * (0.8 + (Math.random() * 0.4));
        let resultText = '';

        if (activeBuff === 'drum') { finalPower *= 1.5; addLog(`【陣太鼓 効果】部隊の戦力が1.5倍になった！`, 'rare'); setActiveBuff(null); } 
        else if (activeBuff === 'hora') { finalPower *= 1.2; addLog(`【法螺貝 効果】部隊の戦力が1.2倍になった！`, 'rare'); setActiveBuff(null); }

        const allyFactions = Object.keys(diplomacyRelations).filter(f => diplomacyRelations[f] === 'alliance');
        let reinforcementText = '';
        const reinforcementChance = Math.min(allyFactions.length * 0.15, 0.6); // 1カ国につき15%、最大60%確率
        if (allyFactions.length > 0 && Math.random() < reinforcementChance) {
          const randomAlly = allyFactions[Math.floor(Math.random() * allyFactions.length)];
          finalPower *= 1.3;
          reinforcementText = `（${randomAlly}軍の援軍あり）`;
          addLog(`【援軍到着】同盟国「${randomAlly}軍」が加勢に駆けつけた！戦力が大幅に上昇！`, 'rare');
        }

        let isVictory = finalPower > targetEnemyPower;
        let isDraw = !isVictory && finalPower > targetEnemyPower * 0.7;
        let rareWares = [];

        if (isVictory) {
          const winSe = new Audio('https://cdn.pixabay.com/download/audio/2021/08/04/audio_0625c1539c.mp3');
          winSe.volume = bgmVolume;
          winSe.play().catch(() => { console.log("SEの自動再生がブロックされました"); });

          let dropText = '';
          if (Math.random() < 0.3) { setInventory(prev => ({ ...prev, tactics: prev.tactics + 1 })); dropText += ' / 兵法書×1'; }
          if (Math.random() < 0.2) { setInventory(prev => ({ ...prev, drum: prev.drum + 1 })); dropText += ' / 陣太鼓×1'; }
          
          if (Math.random() < 0.35) {
            const priceMultiplier = 0.5 + (Math.random() * 0.3); // 0.5倍〜0.8倍の割引価格
            if (Math.random() < 0.5) {
               rareWares.push({ id: 'hora', itemType: 'item', name: '法螺貝', price: Math.floor(3000 * priceMultiplier), rarity: 3, description: '次の出陣で自軍戦力1.2倍。小回りの利く戦具。' });
            }
            const rareWeapons = MASTER_WEAPONS.filter(w => ['wp4', 'wp5', 'wp6', 'wp7', 'wp8'].includes(w.id));
            const pickedWeapon = rareWeapons[Math.floor(Math.random() * rareWeapons.length)];
            rareWares.push({ ...pickedWeapon, itemType: 'weapon', price: Math.floor(pickedWeapon.price * priceMultiplier) });
          }

          if (isDefense) {
            resultText = '防衛成功';
            addLog(`【防衛成功】第${deckIdx + 1}部隊が見事敵を撃退し、${land.name}を守り抜いた！`, 'success');
            const defenseReward = Math.floor(targetEnemyPower / 10);
            addLog(`防衛報酬: 銅銭 +${defenseReward} / 経験値 +${land.exp * 2}${dropText}`, 'success');
            setCopper(prev => prev + defenseReward);
          } else {
            const isAlreadyOccupied = occupiedLands.includes(land.id);
            if (!isAlreadyOccupied) {
              resultText = '大勝・占領';
              addLog(`【占領】第${deckIdx + 1}部隊が敵を撃破し、${land.name}を占領した！`, 'success');
              addLog(`戦利品: 小判 +${land.goldReward} / 銅銭 +${land.reward} / 経験値 +${land.exp}${dropText}`, 'success');
              setGold(prev => prev + land.goldReward); 
              setCopper(prev => prev + land.reward);
              setOccupiedLands(prev => {
                const newOccupied = [...prev, land.id];
                if (newOccupied.length === LANDS.length) {
                   setTimeout(() => {
                     setIsGameClear(true);
                     const clearSe = new Audio('https://cdn.pixabay.com/download/audio/2021/08/04/audio_c6ccf3232f.mp3');
                     clearSe.volume = bgmVolume;
                     clearSe.play().catch(e => console.log("SE blocked", e));
                   }, 2000);
                   addLog("【大祝勝】日ノ本全土を平定！天下統一を成し遂げました！", "rare");
                }
                return newOccupied;
              });
            } else {
              resultText = '掃討完了';
              addLog(`【掃討】領地内の賊を討伐した！`, 'success');
              addLog(`戦利品: 経験値 +${land.exp}${dropText}`, 'success');
            }
          }
          
          setOwnedGenerals(prevGenerals => prevGenerals.map(g => {
            const isActive = activeDeckGenerals.some(ag => ag.uniqueId === g.uniqueId);
            if (!isActive) return g;
            const gainedExp = isDefense ? land.exp * 2 : land.exp;
            let newExp = g.currentExp + gainedExp;
            let newLevel = g.level;
            while (newExp >= newLevel * 100) { newExp -= newLevel * 100; newLevel++; addLog(`【昇級】${g.name} がレベル${newLevel}に昇級した！`, 'rare'); }
            return { ...g, level: newLevel, currentExp: newExp };
          }));
        } else if (isDraw) {
          resultText = '引き分け';
          if (isDefense) {
             addLog(`【引き分け】敵の猛攻をなんとか凌ぎ、${land.name}を防衛した。`, 'warning');
          } else {
             addLog(`【引き分け】両軍痛み分けとなった。部隊は帰還した。`, 'warning');
          }
        } else {
          const loseSe = new Audio('https://cdn.pixabay.com/download/audio/2021/08/04/audio_bb630cc098.mp3');
          loseSe.volume = bgmVolume;
          loseSe.play().catch(() => { console.log("SEの自動再生がブロックされました"); });
          
          if (isDefense) {
            resultText = '防衛失敗';
            addLog(`【防衛失敗】我が軍は壊滅し、${land.name}が敵に奪われてしまった...`, 'error');
            setOccupiedLands(prev => prev.filter(id => id !== land.id));
            
            // 敵の勢力に書き換える
            let newOwner = '群';
            const factionMatch = Object.values(FACTIONS).find(f => targetEnemyName.startsWith(f));
            if (factionMatch) newOwner = factionMatch;
            
            setLANDS(prev => prev.map(l => l.id === land.id ? { ...l, owner: newOwner } : l));

            // 居城が奪われたらゲームオーバー
            if (land.id === capitalLandId) {
              setTimeout(() => setIsGameOver(true), 1500);
              addLog(`【御家滅亡】居城たる${land.name}が陥落...我が軍は滅亡しました...`, 'error');
            }

          } else {
            resultText = '大敗';
            addLog(`【敗北】我が軍は壊滅した...再起を図ろう。`, 'error');
          }
        }

        setBattleScene(prev => ({ ...prev, phase: 'result', resultText, isVictory, isDraw, merchantWares: rareWares }));

        const battlePrompt = `戦国時代の合戦結果です。臨場感のある短い戦況報告（2〜3行程度）を軍記物風に書いてください。【出陣武将】${activeDeckGenerals.map(g => g.name).join(', ')} 【敵軍】兵力 ${targetEnemyPower} の ${targetEnemyName} 【結果】${resultText}${reinforcementText}`;
        const logId = generateId();
        setLogs(prev => [...prev, { id: logId, text: "✨ 戦況報告を記帳中...", type: 'system' }]);
        
        callGemini(battlePrompt, "あなたは戦記を綴る右筆（書記）です。客観的かつ劇的に、古風な文体で短く結果を記してください。").then(text => {
          setLogs(prev => prev.map(log => log.id === logId ? { id: logId, text: `✨ 【戦況報告】\n${text}`, type: 'rare' } : log));
        });
      }, 2500); 
    }, 2000); 
  };

  const closeBattleScene = () => {
    if (battleScene?.wasBgmPlaying && audioRef.current) {
      audioRef.current.play().catch(e => {
        console.log("BGM再開エラー", e);
        setIsBgmPlaying(false);
      });
    }
    
    if (battleScene?.merchantWares?.length > 0) {
      setMerchantEvent({ wares: battleScene.merchantWares });
      addLog(`【行商人】合戦の噂を聞きつけ、行商人が珍しい品を持ち込んできた！`, 'rare');
    }
    
    setBattleScene(null);
    setBattlingLandId(null);
  };

  const handleConsultAdvisor = async () => {
    if (!advisorQuery.trim() || isConsulting) return;
    setIsConsulting(true);
    setAdvisorResponse('');
    const deckInfo = decks.map((deck, idx) => {
      const genStr = deck.filter(id=>id).map(id => {
        const g = ownedGenerals.find(og => og.uniqueId === id);
        return g ? `${g.name}(Lv${g.level}/${g.troop.name})` : '';
      }).join(', ');
      return `第${idx+1}部隊: ${genStr || '空'}`;
    }).join(' | ');

    const prompt = `我が軍の現在の状況は以下の通りじゃ。【現在の編制】${deckInfo} 【所持銅銭】${copper} 【所持小判】${gold} 相談内容: ${advisorQuery}`;
    const response = await callGemini(prompt);
    setAdvisorResponse(response);
    setIsConsulting(false);
  };

  const donateAlliance = () => {
    if (copper < 1000) {
      addLog("銅銭が足りませぬ。", 'error');
      return;
    }
    setCopper(prev => prev - 1000);
    
    setAllianceInfo(prev => {
      let newExp = prev.exp + 100;
      let newLevel = prev.level;
      let newMaxExp = prev.maxExp;
      let levelUpLogs = [];
      
      if (newExp >= newMaxExp) {
        newLevel++;
        newExp -= newMaxExp;
        newMaxExp = Math.floor(newMaxExp * 1.5); 
        const logMsg = `【祝賀】同盟レベルが ${newLevel} に上昇した！同盟技術が強化されたぞ！`;
        addLog(logMsg, 'rare');
        levelUpLogs.push(logMsg);
      }
      
      return {
        ...prev,
        level: newLevel,
        exp: newExp,
        maxExp: newMaxExp,
        logs: [...levelUpLogs, `御館様が1000銅銭を寄付し、同盟経験値が100上昇しました。`, ...prev.logs].slice(0, 5)
      };
    });
    addLog("同盟に寄付を行い、技術発展に貢献しました。", 'success');
  };

  const sendChatMessage = () => {
    if (!chatInput.trim()) return;
    const userText = chatInput;
    setChatMessages(prev => [...prev, {
      id: generateId(),
      sender: '御館様 (あなた)',
      text: userText,
      isSelf: true
    }]);
    setChatInput('');

    const members = allianceInfo.members.filter(m => m.name !== '御館様 (あなた)');
    const replier = members.length > 0 ? members[Math.floor(Math.random() * members.length)].name : '同盟の者';
    const prompt = `盟主が同盟チャットで「${userText}」と発言しました。あなたは「${replier}」として、戦国時代らしい古風な口調で、1〜2行の短く熱い返事をしてください。`;

    setTimeout(async () => {
      const response = await callGemini(prompt, "あなたは戦国武将です。短く、感情豊かに、古風な言葉遣い（〜でござる、〜じゃ等）で返信してください。");
      setChatMessages(prev => [...prev, {
        id: generateId(),
        sender: replier,
        text: response,
        isSelf: false
      }]);
    }, 1000 + Math.random() * 2000); 
  };

  useEffect(() => {
    if (activeTab === 'alliance') {
      chatEndRef.current?.scrollIntoView({ behavior: 'smooth' });
    }
  }, [chatMessages, activeTab]);

  const RarityStars = ({ count }) => (
    <div className="flex">
      {[...Array(count)].map((_, i) => <Star key={i} className="w-3 h-3 text-yellow-400 fill-current" />)}
    </div>
  );

  const Star = (props) => (
    <svg viewBox="0 0 24 24" {...props}>
      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
    </svg>
  );

  return (
    <div className="flex flex-col h-screen bg-stone-900 text-stone-200 font-serif relative">
      
      {/* ＝＝＝ ゲームオーバー モーダル ＝＝＝ */}
      {isGameOver && (
        <div className="absolute inset-0 z-[1000] bg-black/95 flex flex-col items-center justify-center overflow-hidden backdrop-blur-md animate-fade-in px-4">
          <div className="relative z-10 text-center flex flex-col items-center animate-pop-in">
            <Skull className="w-32 h-32 text-red-700 mb-4 animate-pulse drop-shadow-[0_0_30px_rgba(185,28,28,0.8)]" />
            <h1 className="text-6xl md:text-9xl font-black text-transparent bg-clip-text bg-gradient-to-b from-red-500 to-red-900 mb-6 tracking-[0.2em] drop-shadow-2xl" style={{fontFamily: 'serif'}}>御家滅亡</h1>
            <div className="bg-stone-900/80 border-2 border-red-900 p-8 rounded-2xl shadow-[0_0_40px_rgba(153,27,27,0.4)] mb-8 max-w-2xl">
              <p className="text-2xl text-red-200 mb-4 font-bold tracking-widest">本拠地が陥落し、我が軍は瓦解いたしました……</p>
              <p className="text-stone-400 italic mb-2">「夏草や 兵どもが 夢の跡」</p>
              <p className="text-stone-500">志半ばにして、貴殿の野望はここに潰えました。<br/>しかし、この乱世、何度でもやり直すことができます。</p>
            </div>
            <button onClick={() => { setIsGameOver(false); setShowResetModal(true); }} className="px-10 py-4 bg-red-950 hover:bg-red-900 text-red-200 border-2 border-red-700 rounded-full font-bold text-xl shadow-[0_0_20px_rgba(153,27,27,0.5)] transition-all transform hover:scale-105">
              輪廻の果てに（やり直す）
            </button>
          </div>
        </div>
      )}

      {/* ＝＝＝ リセット確認 モーダル ＝＝＝ */}
      {showResetModal && (
        <div className="absolute inset-0 z-[2000] bg-black/80 flex flex-col items-center justify-center overflow-hidden backdrop-blur-sm px-4 animate-fade-in">
          <div className="bg-stone-900 border-4 border-red-700 p-8 rounded-xl max-w-md w-full text-center shadow-[0_0_50px_rgba(220,38,38,0.4)]">

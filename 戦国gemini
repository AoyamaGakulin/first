    if (occupiedLands.includes(landId)) return true;
    if (occupiedLands.length === 0) return landId === 1;

    if (hasNavy) {
      const targetLand = LANDS.find(l => l.id === landId);
      if (targetLand?.isPort) {
        // 自軍が1つでも「港」を占領しているか、同盟国が港を持っているか
        const hasBasePort = occupiedLands.some(id => LANDS.find(l => l.id === id)?.isPort) || 
                            LANDS.some(l => l.isPort && diplomacyRelations[l.owner] === 'alliance');
        if (hasBasePort) return true;
      }
    }

    // 陸路接続の判定（同盟国の領地も自軍領地のように通過可能）
    return ROUTE_CONNECTIONS.some(([a, b]) => {
      if (a === landId) {
        const landB = LANDS.find(l => l.id === b);
        return occupiedLands.includes(b) || diplomacyRelations[landB?.owner] === 'alliance';
      }
      if (b === landId) {
        const landA = LANDS.find(l => l.id === a);
        return occupiedLands.includes(a) || diplomacyRelations[landA?.owner] === 'alliance';
      }
      return false;
    });
  };

  const handleZoom = (newScale) => {
    if (!mapContainerRef.current) {
      setMapScale(newScale);
      return;
    }
    const container = mapContainerRef.current;
    
    const centerX = (container.scrollLeft + container.clientWidth / 2) / (12800 * mapScale);
    const centerY = (container.scrollTop + container.clientHeight / 2) / (9600 * mapScale);

    setMapScale(newScale);

    setTimeout(() => {
      if (!mapContainerRef.current) return;
      const newScrollLeft = (12800 * newScale) * centerX - container.clientWidth / 2;
      const newScrollTop = (9600 * newScale) * centerY - container.clientHeight / 2;
      
      container.scrollLeft = newScrollLeft;
      container.scrollTop = newScrollTop;
    }, 0);
  };

  const handleZoomIn = () => handleZoom(Math.min(mapScale + 0.1, 2.0));
  const handleZoomOut = () => handleZoom(Math.max(mapScale - 0.1, 0.1));

  const handleMapMouseDown = (e) => {
    if (!mapContainerRef.current) return;
    setIsDragging(true);
    setDragStart({
      x: e.pageX,
      y: e.pageY,
      scrollLeft: mapContainerRef.current.scrollLeft,
      scrollTop: mapContainerRef.current.scrollTop,
    });
    setDragDistance(0);
  };

  const handleMapMouseMove = (e) => {
    if (!isDragging || !mapContainerRef.current) return;
    e.preventDefault(); 
    const x = e.pageX;
    const y = e.pageY;
    const dx = x - dragStart.x;
    const dy = y - dragStart.y;
    mapContainerRef.current.scrollLeft = dragStart.scrollLeft - dx;
    mapContainerRef.current.scrollTop = dragStart.scrollTop - dy;
    setDragDistance(prev => prev + Math.abs(dx) + Math.abs(dy));
  };

  const handleMapMouseUp = () => {
    setIsDragging(false);
  };

